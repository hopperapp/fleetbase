{
    "name": "hopper/rides-api",
    "version": "0.1.0",
    "description": "Ride-Hailing Extension for Fleetbase — Passenger Transport, Bidding, and On-Demand Rides",
    "keywords": [
        "fleetbase-extension",
        "rides",
        "ride-hailing",
        "passenger-transport",
        "taxi",
        "on-demand"
    ],
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Hopper",
            "email": "app@hopper.now"
        }
    ],
    "require": {
        "php": "^8.0",
        "fleetbase/core-api": "*",
        "fleetbase/fleetops-api": "*",
        "fleetbase/storefront-api": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.34.1",
        "pestphp/pest": "^2.33.2"
    },
    "autoload": {
        "psr-4": {
            "Hopper\\Rides\\": "server/src/",
            "Hopper\\Rides\\Seeders\\": "server/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hopper\\Rides\\Tests\\": "server/tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Hopper\\Rides\\Providers\\RidesServiceProvider",
                "Hopper\\Rides\\Providers\\EventServiceProvider"
            ]
        },
        "fleetbase": {
            "create-database": "rides",
            "sandbox-migrations": false
        }
    },
    "config": {
        "vendor-dir": "./server_vendor",
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
