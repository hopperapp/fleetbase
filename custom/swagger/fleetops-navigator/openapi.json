{
  "openapi": "3.0.3",
  "info": {
    "title": "Navigator Driver API",
    "version": "1.0.0",
    "description": "Driver-facing endpoints for the Navigator App (FleetOps v1)."
  },
  "servers": [
    { "url": "http://localhost:8000/v1" }
  ],
  "tags": [
    { "name": "Drivers", "description": "Driver auth, profile, and device" },
    { "name": "Orders", "description": "Order lifecycle for drivers" },
    { "name": "Proofs", "description": "Proof of delivery uploads" },
    { "name": "Navigator", "description": "Navigator onboarding settings" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "FleetbaseKeyOrDriverToken"
      }
    },
    "schemas": {
      "DriverLoginSmsRequest": {
        "type": "object",
        "required": ["phone"],
        "properties": {
          "phone": { "type": "string", "example": "+967772537138" }
        }
      },
      "DriverVerifyCodeRequest": {
        "type": "object",
        "required": ["identity", "code"],
        "properties": {
          "identity": { "type": "string", "example": "+967772537138" },
          "code": { "type": "string", "example": "123456" },
          "for": { "type": "string", "example": "driver_login" },
          "name": { "type": "string", "example": "Omar Driver" },
          "phone": { "type": "string", "example": "+967772537138" },
          "email": { "type": "string", "example": "driver@example.com" }
        }
      },
      "DriverLoginRequest": {
        "type": "object",
        "required": ["identity", "password"],
        "properties": {
          "identity": { "type": "string", "example": "+967772537138" },
          "password": { "type": "string", "example": "P@ssw0rd!" }
        }
      },
      "DriverRegisterDeviceRequest": {
        "type": "object",
        "required": ["token", "platform"],
        "properties": {
          "token": { "type": "string", "example": "fcm_device_token" },
          "platform": { "type": "string", "example": "android" },
          "os": { "type": "string", "example": "android" }
        }
      },
      "DriverTrackRequest": {
        "type": "object",
        "required": ["latitude", "longitude"],
        "properties": {
          "latitude": { "type": "number", "example": 15.3694 },
          "longitude": { "type": "number", "example": 44.1910 },
          "altitude": { "type": "number", "example": 2200 },
          "heading": { "type": "number", "example": 180 },
          "speed": { "type": "number", "example": 35 }
        }
      },
      "DriverToggleOnlineRequest": {
        "type": "object",
        "properties": {
          "online": { "type": "boolean", "example": true }
        }
      },
      "DriverSwitchOrganizationRequest": {
        "type": "object",
        "required": ["next"],
        "properties": {
          "next": { "type": "string", "example": "company_abc123" }
        }
      },
      "OrderUpdateActivityRequest": {
        "type": "object",
        "properties": {
          "activity": {
            "type": "object",
            "properties": {
              "code": { "type": "string", "example": "picked_up" },
              "name": { "type": "string", "example": "Picked Up" },
              "completed": { "type": "boolean", "example": true },
              "timestamp": { "type": "string", "example": "2026-03-08T12:00:00Z" }
            }
          },
          "proof": {
            "type": "object",
            "properties": {
              "remarks": { "type": "string", "example": "Left at door" }
            }
          },
          "skip_dispatch": { "type": "boolean", "example": false }
        }
      },
      "OrderCaptureQrRequest": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": { "type": "string", "example": "uuid_or_qr_payload" },
          "raw_data": { "type": "string", "example": "RAW_QR_DATA" },
          "data": {
            "type": "object",
            "example": { "scanned_at": "2026-03-08T12:05:00Z" }
          }
        }
      },
      "OrderCaptureSignatureRequest": {
        "type": "object",
        "required": ["signature"],
        "properties": {
          "signature": { "type": "string", "example": "data:image/png;base64,iVBORw0..." },
          "remarks": { "type": "string", "example": "Signed by customer" },
          "data": {
            "type": "object",
            "example": { "signed_by": "Customer" }
          }
        }
      },
      "OrderCapturePhotoRequest": {
        "type": "object",
        "required": ["photos"],
        "properties": {
          "photos": {
            "type": "array",
            "items": { "type": "string", "example": "iVBORw0..." }
          },
          "remarks": { "type": "string", "example": "Package at door" },
          "data": {
            "type": "object",
            "example": { "angle": "front" }
          }
        }
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/drivers/login-with-sms": {
      "post": {
        "tags": ["Drivers"],
        "summary": "Send login code by SMS",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DriverLoginSmsRequest" },
              "example": { "phone": "+967772537138" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/verify-code": {
      "post": {
        "tags": ["Drivers"],
        "summary": "Verify login code",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DriverVerifyCodeRequest" },
              "example": { "identity": "+967772537138", "code": "123456", "for": "driver_login" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/login": {
      "post": {
        "tags": ["Drivers"],
        "summary": "Login with password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DriverLoginRequest" },
              "example": { "identity": "+967772537138", "password": "P@ssw0rd!" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/register-device": {
      "post": {
        "tags": ["Drivers"],
        "summary": "Register device (current driver)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DriverRegisterDeviceRequest" },
              "example": { "token": "fcm_device_token", "platform": "android" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/{id}/register-device": {
      "post": {
        "tags": ["Drivers"],
        "summary": "Register device for driver",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "driver_abc123" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DriverRegisterDeviceRequest" },
              "example": { "token": "fcm_device_token", "platform": "android" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/{id}/track": {
      "post": {
        "tags": ["Drivers"],
        "summary": "Update driver location",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "driver_abc123" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DriverTrackRequest" },
              "example": { "latitude": 15.3694, "longitude": 44.1910, "altitude": 2200, "heading": 180, "speed": 35 }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/{id}/toggle-online": {
      "post": {
        "tags": ["Drivers"],
        "summary": "Toggle driver online status",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "driver_abc123" } }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DriverToggleOnlineRequest" },
              "example": { "online": true }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/{id}/switch-organization": {
      "post": {
        "tags": ["Drivers"],
        "summary": "Switch driver organization",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "driver_abc123" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DriverSwitchOrganizationRequest" },
              "example": { "next": "company_abc123" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/{id}/organizations": {
      "get": {
        "tags": ["Drivers"],
        "summary": "List driver organizations",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "driver_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/drivers/{id}/current-organization": {
      "get": {
        "tags": ["Drivers"],
        "summary": "Get driver current organization",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "driver_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Query orders",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "example": "started" } },
          { "name": "driver", "in": "query", "schema": { "type": "string", "example": "driver_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/start": {
      "post": {
        "tags": ["Orders"],
        "summary": "Start order",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/update-activity": {
      "post": {
        "tags": ["Orders"],
        "summary": "Update order activity",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderUpdateActivityRequest" },
              "example": {
                "activity": { "code": "picked_up", "name": "Picked Up", "completed": true, "timestamp": "2026-03-08T12:00:00Z" },
                "skip_dispatch": false
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/complete": {
      "post": {
        "tags": ["Orders"],
        "summary": "Complete order",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/tracker": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get tracker data",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/eta": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get ETA data",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/set-destination/{placeId}": {
      "post": {
        "tags": ["Orders"],
        "summary": "Set current destination",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } },
          { "name": "placeId", "in": "path", "required": true, "schema": { "type": "string", "example": "place_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/comments": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order comments",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/capture-signature": {
      "post": {
        "tags": ["Proofs"],
        "summary": "Capture signature",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderCaptureSignatureRequest" },
              "example": { "signature": "data:image/png;base64,iVBORw0...", "remarks": "Signed by customer" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/capture-qr": {
      "post": {
        "tags": ["Proofs"],
        "summary": "Capture QR scan",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderCaptureQrRequest" },
              "example": { "code": "uuid_or_qr_payload", "raw_data": "RAW_QR_DATA" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/capture-photo": {
      "post": {
        "tags": ["Proofs"],
        "summary": "Capture photo proof",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderCapturePhotoRequest" },
              "example": { "photos": ["iVBORw0..."], "remarks": "Package at door" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders/{id}/proofs": {
      "get": {
        "tags": ["Proofs"],
        "summary": "List proofs",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "example": "order_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/onboard/driver-onboard-settings/{companyId}": {
      "get": {
        "tags": ["Navigator"],
        "summary": "Get driver onboard settings",
        "parameters": [
          { "name": "companyId", "in": "path", "required": true, "schema": { "type": "string", "example": "company_abc123" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
