    "/driver/rides/{id}/reject": {
      "post": {
        "summary": "Reject Assigned Ride",
        "description": "Allows a specifically assigned driver to reject an exclusive preferred ride ping, releasing it back to the global broadcast network.",
        "tags": [
          "Driver - Lifecycle"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "driverToken": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Public ID or UUID of the Ride."
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": {
                    "type": "string",
                    "description": "Optional string explaining why the assigned driver is rejecting the Ping."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ride successfully rejected by the favorite driver and re-broadcasted to the remaining public fleet."
          }
        }
      }
    },
    "/driver/rides/{id}/cancel": {
      "post": {
        "summary": "Cancel / Drop out of Ride",
        "description": "If a driver cancels an accepted ride, it executes a 'rebound strategy', unassigning them and returning the ride to the bidding pool without totally destroying it.",
        "tags": [
          "Driver - Rides"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "driverToken": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
