{
  "openapi": "3.0.3",
  "info": {
    "title": "Hopper Rides API",
    "description": "مواصفات واجهة برمجة التطبيقات (API) لإضافة @hopper/rides المخصصة التي تتعامل مع وظائف حجز الرحلات بشكل طبيعي داخل Fleetbase.",
    "version": "1.0.0",
    "contact": {
      "name": "Hopper Development API"
    }
  },
  "servers": [
    {
      "url": "/rides/v1",
      "description": "خادم التطوير المحلي"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "customerToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Customer-Token"
      },
      "driverToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Driver-Token"
      }
    },
    "schemas": {
      "Ride": {
        "type": "object",
        "description": "JSON representation of a Ride resource",
        "properties": {
          "public_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "customer": {
            "type": "object"
          },
          "driver": {
            "type": "object"
          },
          "order": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string"
              },
              "order_config": {
                "type": "object",
                "properties": {
                  "flow": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              },
              "next_activity": {
                "type": "object",
                "nullable": true
              },
              "allowed_next_activities": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/customer/vehicles": {
      "get": {
        "summary": "List Vehicle Categories",
        "tags": [
          "Customer - Vehicles"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "قائمة بفئات المركبات المتاحة في سياق المتجر."
          }
        }
      }
    },
    "/customer/estimate": {
      "post": {
        "summary": "Estimate Ride Fare",
        "tags": [
          "Customer - Rides"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "distance_meters": {
                    "type": "integer"
                  },
                  "duration_seconds": {
                    "type": "integer"
                  },
                  "pickup_lat": {
                    "type": "number"
                  },
                  "pickup_lng": {
                    "type": "number"
                  },
                  "dropoff_lat": {
                    "type": "number"
                  },
                  "dropoff_lng": {
                    "type": "number"
                  },
                  "vehicle_sub_category_uuid": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "تقديرات الأجر حسب الفئة."
          }
        }
      }
    },
    "/customer/rides": {
      "post": {
        "summary": "Request a Ride",
        "tags": [
          "Customer - Rides"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "vehicle_category_uuid": {
                    "type": "string"
                  },
                  "pickup_latitude": {
                    "type": "number"
                  },
                  "pickup_longitude": {
                    "type": "number"
                  },
                  "dropoff_latitude": {
                    "type": "number"
                  },
                  "dropoff_longitude": {
                    "type": "number"
                  },
                  "distance_meters": {
                    "type": "integer"
                  },
                  "duration_seconds": {
                    "type": "integer"
                  },
                  "pricing_method": {
                    "type": "string",
                    "enum": [
                      "auto",
                      "bidding"
                    ],
                    "description": "'auto' يستخدم حاسبة الأجرة الداخلية بناءً على المسافة والمدة. 'bidding' يسمح للعميل باقتراح سعر (offered_fare) يمكن للسائقين المزايدة عليه أو قبوله."
                  },
                  "offered_fare": {
                    "type": "number",
                    "description": "مطلوب إذا كان pricing_method هو 'bidding'. المبلغ (بالوحدات الصغرى) الذي يقترحه العميل لدفعه مقابل الرحلة."
                  },
                  "store_uuid": {
                    "type": "string",
                    "description": "Optional. The UUID of the store if the ride is booked through a specific merchant. Leave null for general network rides."
                  },
                  "vehicle_sub_category_uuid": {
                    "type": "string",
                    "description": "اختياري. الـ UUID لفئة فرعية محددة للمركبة (مثل 'دراجة نارية بفرو') لتخصيص الطلب."
                  },
                  "is_scheduled": {
                    "type": "boolean",
                    "description": "Optional. Flag to indicating if the ride is scheduled for a future time. Required to sync with FleetOps Scheduler."
                  },
                  "scheduled_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Optional. Required if is_scheduled is true. The future datetime when the ride should occur."
                  },
                  "pickup_place_uuid": {
                    "type": "string",
                    "description": "Optional. The UUID of a saved Place to use as pickup. If provided, pickup_latitude and pickup_longitude are omitted."
                  },
                  "dropoff_place_uuid": {
                    "type": "string",
                    "description": "Optional. The UUID of a saved Place to use as dropoff. If provided, dropoff_latitude and dropoff_longitude are omitted."
                  },
                  "preferred_driver_uuid": {
                    "type": "string",
                    "description": "Optional. The UUID or Public ID of a favorite driver. WARNING: If this driver is offline or active on another ride, the API will fail immediately with a 422 Unprocessable Entity error (Synchronous Busy Check)."
                  }
                },
                "required": [
                  "vehicle_category_uuid",
                  "distance_meters",
                  "duration_seconds",
                  "pricing_method"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "تم طلب الرحلة بنجاح."
          }
        }
      }
    },
    "/customer/rides/{id}/bids": {
      "get": {
        "summary": "View Active Bids",
        "tags": [
          "Customer - Rides"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "قائمة عروض السائقين النشطة."
          }
        }
      }
    },
    "/customer/rides/{id}/accept-bid": {
      "post": {
        "summary": "Accept a Bid",
        "tags": [
          "Customer - Rides"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bid_public_id": {
                    "type": "string"
                  },
                  "bid_uuid": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "تم قبول العرض وتم إنشاء طلب إرسال محلي."
          }
        }
      }
    },
    "/customer/rides/{id}/cancel": {
      "post": {
        "summary": "Cancel Ride",
        "description": "Cancel the ride booking. Protected by en_route validation ensuring customers cannot cancel if driver is arriving.",
        "tags": [
          "Customer - Rides"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cancel_reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "تم إلغاء الرحلة بنجاح."
          },
          "422": {
            "description": "لا يمكن الإلغاء في هذه المرحلة لأن السائق في الطريق."
          }
        }
      }
    },
    "/customer/rides/{id}/rate": {
      "post": {
        "summary": "Rate Driver",
        "tags": [
          "Customer - Rides"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "comment": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "تم تقييم السائق بنجاح."
          }
        }
      }
    },
    "/customer/favorite-drivers": {
      "get": {
        "summary": "List Favorite Drivers",
        "tags": [
