{
  "openapi": "3.0.3",
  "info": {
    "title": "Hopper Rides API",
    "description": "API specifications for the custom @hopper/rides extension handling Ride-Hailing functionality natively within Fleetbase.",
    "version": "1.0.0",
    "contact": {
      "name": "Hopper Development API"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/rides/v1",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "customerToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Customer-Token"
      },
      "driverToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Driver-Token"
      }
    }
  },
  "paths": {
    "/customer/vehicles": {
      "get": {
        "summary": "List Vehicle Categories",
        "tags": ["Customer - Vehicles"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "responses": {
          "200": {
            "description": "List of available vehicle categories in the store context."
          }
        }
      }
    },
    "/customer/estimate": {
      "post": {
        "summary": "Estimate Ride Fare",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "distance_meters": { "type": "integer" },
                  "duration_seconds": { "type": "integer" },
                  "pickup_lat": { "type": "number" },
                  "pickup_lng": { "type": "number" },
                  "dropoff_lat": { "type": "number" },
                  "dropoff_lng": { "type": "number" },
                  "vehicle_sub_category_uuid": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Fare estimates by category." }
        }
      }
    },
    "/customer/rides": {
      "post": {
        "summary": "Request a Ride",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "vehicle_category_uuid": { "type": "string" },
                  "pickup_latitude": { "type": "number" },
                  "pickup_longitude": { "type": "number" },
                  "dropoff_latitude": { "type": "number" },
                  "dropoff_longitude": { "type": "number" },
                  "distance_meters": { "type": "integer" },
                  "duration_seconds": { "type": "integer" },
                  "pricing_method": { 
                    "type": "string", 
                    "enum": ["auto", "bidding"],
                    "description": "'auto' uses the internal fare calculator based on distance/duration. 'bidding' allows the customer to propose a price (offered_fare) which drivers can then outbid or accept."
                  },
                  "offered_fare": { 
                    "type": "number",
                    "description": "Required if pricing_method is 'bidding'. The amount (in minor units) the customer is offering to pay for the ride."
                  },
                  "store_uuid": {
                    "type": "string",
                    "description": "The unique identifier of the Storefront this ride belongs to. Used for multi-tenant and branch-specific context."
                  },
                  "vehicle_sub_category_uuid": {
                    "type": "string",
                    "description": "Optional. The UUID of a specific vehicle sub-category (e.g., 'Motorcycle with Fur') to tailor the request."
                  }
                },
                "required": ["vehicle_category_uuid", "pickup_latitude", "pickup_longitude", "dropoff_latitude", "dropoff_longitude", "distance_meters", "duration_seconds", "pricing_method"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Ride requested successfully." }
        }
      }
    },
    "/customer/rides/{id}/bids": {
      "get": {
        "summary": "View Active Bids",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of active driver bids." }
        }
      }
    },
    "/customer/rides/{id}/accept-bid": {
      "post": {
        "summary": "Accept a Bid",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bid_public_id": { "type": "string" }
                },
                "required": ["bid_public_id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Bid accepted and Dispatch Native Order Created." }
        }
      }
    },
    "/customer/rides/{id}/rate": {
      "post": {
        "summary": "Rate Driver",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "comment": { "type": "string" },
                  "tags": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Driver rated successfully." }
        }
      }
    },
    "/driver/rides/available": {
      "get": {
        "summary": "Discover Nearby Available Rides",
        "tags": ["Driver - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "driverToken": [] }
        ],
        "responses": {
          "200": { "description": "List of un-bid matching rides." }
        }
      }
    },
    "/driver/rides/{id}": {
      "get": {
        "summary": "Get Ride Details",
        "description": "Fetch current state of an active ride, including the linked FleetOps Order and its dynamic status flow.",
        "tags": ["Driver - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "driverToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "The ride resource with expanded relationships.",
            "content": {
              "application/json": {
                "schema": {
                   "type": "object",
                   "properties": {
                     "ride": { "$ref": "#/components/schemas/Ride" }
                   }
                }
              }
            }
          },
          "403": { "description": "Unauthorized - Driver is not assigned to this ride." }
        }
      }
    },
    "/driver/bids/{rideId}": {
      "post": {
        "summary": "Submit Bid",
        "tags": ["Driver - Bids"],
        "security": [
          { "bearerAuth": [] },
          { "driverToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "rideId", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": { "type": "integer" },
                  "estimated_arrival_min": { "type": "integer" }
                },
                "required": ["amount"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Bid submitted." }
        }
      }
    },
    "/driver/rides/{id}/status": {
      "post": {
        "summary": "Update Ride Status (Dynamic)",
        "tags": ["Driver - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "driverToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "example": "arrived", "description": "Status code (e.g., arrived, started, completed)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Status updated and synced with FleetOps Order." }
        }
      }
    },
    "/driver/rides/{id}/rate": {
      "post": {
        "summary": "Rate Passenger",
        "tags": ["Driver - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "driverToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "comment": { "type": "string" },
                  "tags": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Passenger rated successfully." }
        }
      }
    },
    "/driver/rides/{id}/start": {
      "post": {
        "summary": "Start Trip (Legacy)",
        "tags": ["Driver - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "driverToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Trip Status updated to IN_TRANSIT." }
        }
      }
    },
    "/admin/vehicle-categories": {
      "get": {
        "summary": "List Vehicle Categories",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "List of vehicle categories."
          }
        }
      },
      "post": {
        "summary": "Create Vehicle Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "base_fare": { "type": "integer" },
                  "per_km_fare": { "type": "integer" },
                  "per_min_fare": { "type": "integer" },
                  "min_fare": { "type": "integer" },
                  "currency": { "type": "string" },
                  "sort_order": { "type": "integer" },
                  "is_active": { "type": "boolean" }
                },
                "required": ["name", "key", "base_fare", "per_km_fare", "per_min_fare", "min_fare"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Vehicle Category created." }
        }
      }
    },
    "/admin/vehicle-categories/{id}": {
      "get": {
        "summary": "Get Vehicle Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Vehicle Category details." }
        }
      },
      "put": {
        "summary": "Update Vehicle Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "base_fare": { "type": "integer" },
                  "per_km_fare": { "type": "integer" },
                  "per_min_fare": { "type": "integer" },
                  "min_fare": { "type": "integer" },
                  "currency": { "type": "string" },
                  "sort_order": { "type": "integer" },
                  "is_active": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Vehicle Category updated." }
        }
      },
      "delete": {
        "summary": "Delete Vehicle Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Vehicle Category deleted." }
        }
      }
    },
    "/admin/vehicle-sub-categories": {
      "get": {
        "summary": "List Vehicle Sub Categories",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "List of vehicle sub categories."
          }
        }
      },
      "post": {
        "summary": "Create Vehicle Sub Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "vehicle_category_uuid": { "type": "string" },
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "fare_multiplier": { "type": "number", "format": "float" },
                  "sort_order": { "type": "integer" },
                  "is_active": { "type": "boolean" }
                },
                "required": ["vehicle_category_uuid", "name", "key"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Vehicle Sub Category created." }
        }
      }
    },
    "/admin/vehicle-sub-categories/{id}": {
      "get": {
        "summary": "Get Vehicle Sub Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Vehicle Sub Category details." }
        }
      },
      "put": {
        "summary": "Update Vehicle Sub Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "vehicle_category_uuid": { "type": "string" },
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "fare_multiplier": { "type": "number", "format": "float" },
                  "sort_order": { "type": "integer" },
                  "is_active": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Vehicle Sub Category updated." }
        }
      },
      "delete": {
        "summary": "Delete Vehicle Sub Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Vehicle Sub Category deleted." }
        }
      }
    },
    "/profiles/{type}/{id}/reviews": {
      "get": {
        "summary": "Get Profile Review History",
        "description": "Fetch a paginated list of reviews for a specific driver or customer profile.",
        "tags": ["General - Profiles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "type", "required": true, "schema": { "type": "string", "enum": ["driver", "customer"] } },
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" }, "description": "Public ID of the driver or customer contact." },
          { "in": "query", "name": "limit", "schema": { "type": "integer", "default": 15 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of reviews.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reviews": { "type": "array", "items": { "type": "object" } },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "current_page": { "type": "integer" },
                        "last_page": { "type": "integer" },
                        "total": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/drivers/leaderboard": {
      "get": {
        "summary": "Driver Leaderboard",
        "description": "Returns a paginated list of all active drivers sorted by their total earnings and completed ride counts.",
        "tags": ["Admin - Drivers"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "query", "name": "sort", "schema": { "type": "string", "enum": ["total_earnings", "completed_rides"], "default": "total_earnings" } },
          { "in": "query", "name": "limit", "schema": { "type": "integer", "default": 15 } }
        ],
        "responses": {
          "200": { "description": "Leaderboard data for all active drivers." }
        }
      }
    },
    "/admin/drivers/{id}/stats": {
      "get": {
        "summary": "Detailed Driver Stats",
        "description": "Fetch real-time earnings, rating, and ride counts for a specific driver.",
        "tags": ["Admin - Drivers"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" }, "description": "Public ID of the driver." }
        ],
        "responses": {
          "200": { "description": "Aggregated driver statistics." }
        }
      }
    }
  }
}
