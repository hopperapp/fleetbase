    "/driver/rides/{id}/status": {
      "post": {
        "summary": "Update Ride Status (Dynamic)",
        "tags": [
          "Driver - Rides"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "driverToken": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
