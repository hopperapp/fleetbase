{
  "openapi": "3.0.3",
  "info": {
    "title": "Hopper Rides API",
    "description": "API specifications for the custom @hopper/rides extension handling Ride-Hailing functionality natively within Fleetbase.",
    "version": "1.0.0",
    "contact": {
      "name": "Hopper Development API"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/rides/v1",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "customerToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Customer-Token"
      },
      "driverToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Driver-Token"
      }
    }
  },
  "paths": {
    "/customer/vehicles": {
      "get": {
        "summary": "List Vehicle Categories",
        "tags": ["Customer - Vehicles"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "responses": {
          "200": {
            "description": "List of available vehicle categories in the store context."
          }
        }
      }
    },
    "/customer/estimate": {
      "post": {
        "summary": "Estimate Ride Fare",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "distance_meters": { "type": "integer" },
                  "duration_seconds": { "type": "integer" }
                },
                "required": ["distance_meters", "duration_seconds"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Fare estimates by category." }
        }
      }
    },
    "/customer/rides": {
      "post": {
        "summary": "Request a Ride",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "vehicle_category_uuid": { "type": "string" },
                  "pickup_latitude": { "type": "number" },
                  "pickup_longitude": { "type": "number" },
                  "dropoff_latitude": { "type": "number" },
                  "dropoff_longitude": { "type": "number" },
                  "distance_meters": { "type": "integer" },
                  "duration_seconds": { "type": "integer" },
                  "pricing_method": { "type": "string", "enum": ["auto", "fixed", "bidding"] }
                },
                "required": ["vehicle_category_uuid", "pickup_latitude", "pickup_longitude", "dropoff_latitude", "dropoff_longitude", "distance_meters", "duration_seconds", "pricing_method"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Ride requested successfully." }
        }
      }
    },
    "/customer/rides/{id}/bids": {
      "get": {
        "summary": "View Active Bids",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of active driver bids." }
        }
      }
    },
    "/customer/rides/{id}/accept-bid": {
      "post": {
        "summary": "Accept a Bid",
        "tags": ["Customer - Rides"],
        "security": [
          { "bearerAuth": [] },
          { "customerToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bid_public_id": { "type": "string" }
                },
                "required": ["bid_public_id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Bid accepted and Dispatch Native Order Created." }
        }
      }
    },
    "/driver/rides/available": {
      "get": {
        "summary": "Discover Nearby Available Rides",
        "tags": ["Driver - Rides"],
        "security": [
          { "driverToken": [] }
        ],
        "responses": {
          "200": { "description": "List of un-bid matching rides." }
        }
      }
    },
    "/driver/bids/{rideId}": {
      "post": {
        "summary": "Submit Bid",
        "tags": ["Driver - Bids"],
        "security": [
          { "driverToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "rideId", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": { "type": "integer" },
                  "estimated_arrival_min": { "type": "integer" }
                },
                "required": ["amount"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Bid submitted." }
        }
      }
    },
    "/driver/rides/{id}/start": {
      "post": {
        "summary": "Start Trip",
        "tags": ["Driver - Rides"],
        "security": [
          { "driverToken": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Trip Status updated to IN_TRANSIT." }
        }
      }
    },
    "/admin/vehicle-categories": {
      "get": {
        "summary": "List Vehicle Categories",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "List of vehicle categories."
          }
        }
      },
      "post": {
        "summary": "Create Vehicle Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "base_fare": { "type": "integer" },
                  "per_km_fare": { "type": "integer" },
                  "per_min_fare": { "type": "integer" },
                  "min_fare": { "type": "integer" },
                  "currency": { "type": "string" },
                  "sort_order": { "type": "integer" },
                  "is_active": { "type": "boolean" }
                },
                "required": ["name", "key", "base_fare", "per_km_fare", "per_min_fare", "min_fare"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Vehicle Category created." }
        }
      }
    },
    "/admin/vehicle-categories/{id}": {
      "get": {
        "summary": "Get Vehicle Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Vehicle Category details." }
        }
      },
      "put": {
        "summary": "Update Vehicle Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "base_fare": { "type": "integer" },
                  "per_km_fare": { "type": "integer" },
                  "per_min_fare": { "type": "integer" },
                  "min_fare": { "type": "integer" },
                  "currency": { "type": "string" },
                  "sort_order": { "type": "integer" },
                  "is_active": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Vehicle Category updated." }
        }
      },
      "delete": {
        "summary": "Delete Vehicle Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Vehicle Category deleted." }
        }
      }
    },
    "/admin/vehicle-sub-categories": {
      "get": {
        "summary": "List Vehicle Sub Categories",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "List of vehicle sub categories."
          }
        }
      },
      "post": {
        "summary": "Create Vehicle Sub Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "vehicle_category_uuid": { "type": "string" },
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "fare_multiplier": { "type": "number", "format": "float" },
                  "sort_order": { "type": "integer" },
                  "is_active": { "type": "boolean" }
                },
                "required": ["vehicle_category_uuid", "name", "key"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Vehicle Sub Category created." }
        }
      }
    },
    "/admin/vehicle-sub-categories/{id}": {
      "get": {
        "summary": "Get Vehicle Sub Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Vehicle Sub Category details." }
        }
      },
      "put": {
        "summary": "Update Vehicle Sub Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "vehicle_category_uuid": { "type": "string" },
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "fare_multiplier": { "type": "number", "format": "float" },
                  "sort_order": { "type": "integer" },
                  "is_active": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Vehicle Sub Category updated." }
        }
      },
      "delete": {
        "summary": "Delete Vehicle Sub Category",
        "tags": ["Admin - Vehicles"],
        "security": [
          { "bearerAuth": [] }
        ],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Vehicle Sub Category deleted." }
        }
      }
    }
  }
}
