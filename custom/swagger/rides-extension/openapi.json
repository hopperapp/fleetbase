            "description": "Driver successfully removed from the customer's favorite list."
          }
        }
      }
    },
    "/customer/places": {
      "get": {
        "summary": "List Saved Places",
        "tags": [
          "Customer - Places"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Array of places owned natively by the customer."
          }
        }
      },
      "post": {
        "summary": "Save a new Location",
        "tags": [
          "Customer - Places"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "customerToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Home",
                    "description": "Location Title."
                  },
                  "street1": {
                    "type": "string",
                    "example": "123 Main St",
                    "description": "Street name or generic text for the address."
                  },
                  "street2": {
                    "type": "string",
                    "description": "Optional secondary street address."
                  },
                  "city": {
                    "type": "string",
                    "description": "City name."
                  },
                  "province": {
                    "type": "string",
                    "description": "Province or state."
                  },
                  "postal_code": {
                    "type": "string",
                    "description": "Postal or ZIP code."
                  },
                  "neighborhood": {
                    "type": "string",
                    "description": "Neighborhood name."
                  },
                  "district": {
                    "type": "string",
                    "description": "District name."
                  },
                  "building": {
                    "type": "string",
                    "example": "Apt 4B",
                    "description": "Optional apartment or building number details."
                  },
                  "security_access_code": {
                    "type": "string",
                    "description": "Optional gate or security code."
                  },
                  "country": {
                    "type": "string",
                    "description": "Country code or name."
                  },
                  "remarks": {
                    "type": "string",
                    "description": "Optional custom remarks specific to this location."
                  },
                  "phone": {
                    "type": "string",
                    "example": "+123456789",
                    "description": "Phone number specific to this place if needed."
                  },
                  "type": {
                    "type": "string",
                    "example": "apartment",
                    "description": "Location type e.g., home, company, apartment."
                  },
                  "latitude": {
                    "type": "number",
                    "description": "The explicit float latitude coordinate."
                  },
                  "longitude": {
                    "type": "number",
                    "description": "The explicit float longitude coordinate."
                  },
                  "meta": {
                    "type": "object",
                    "properties": {
                      "driver_notes": {
                        "type": "string",
                        "example": "Call me upon arrival."
                      }
                    },
                    "description": "Optional arbitrary metadata map (JSON). Ideal for storing Custom driver notes."
                  }
                },
                "required": [
                  "name",
                  "latitude",
                  "longitude"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Place securely created and mapped polymorphism to the customer."
          }
        }
      }
    },
